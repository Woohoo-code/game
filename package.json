{
  "name": "monster-slayer",
  "private": true,
  "version": "1.2.9",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build --mode electron",
    "compress-assets": "node scripts/compress-assets.mjs",
    "convert-fbx-to-glb": "node scripts/convert-fbx-to-glb.mjs",
    "convert-terrain": "node scripts/convert-terrain-webp.mjs",
    "purge-css": "purgecss --css src/styles.css --content src/**/*.tsx --output src/styles.css",
    "electron": "npm run build:electron && electron .",
    "pack:win": "npm run build:electron && electron-builder --win portable",
    "pack:mac": "npm run build:electron && electron-builder --mac dmg",
    "pack:linux": "npm run build:electron && electron-builder --linux AppImage",
    "pack:all": "npm run build:electron && electron-builder -mwl",
    "coop-server": "node server/coop-signaling.mjs",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -b gh-pages"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "phaser": "^3.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.167.0",
    "three-stdlib": "^2.36.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^41.2.2",
    "electron-builder": "^25.1.8",
    "fbx2gltf": "^0.9.7-p1",
    "gh-pages": "^6.3.0",
    "meshoptimizer": "^1.1.1",
    "purgecss": "^8.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "io.github.woohoo-code.monster-slayer",
    "productName": "Monster Slayer",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png",
      "artifactName": "MonsterSlayer-${version}-Portable.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "artifactName": "MonsterSlayer-${version}-Mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "artifactName": "MonsterSlayer-${version}-Linux.${ext}"
    }
  }
}
