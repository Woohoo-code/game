{
  "name": "monster-slayer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build --mode electron",
    "electron": "npm run build:electron && electron .",
    "pack:win": "npm run build:electron && electron-builder --win portable",
    "coop-server": "node server/coop-signaling.mjs",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -b gh-pages"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "phaser": "^3.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.167.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "gh-pages": "^6.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "io.github.woohoo-code.monster-slayer",
    "productName": "Monster Slayer",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*"
    ],
    "asar": true,
    "win": {
      "target": ["portable"],
      "artifactName": "MonsterSlayer-${version}-Portable.${ext}",
      "signAndEditExecutable": false
    }
  }
}
